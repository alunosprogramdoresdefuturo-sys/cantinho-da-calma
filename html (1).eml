<!DOCTYPE html>
<html lang=3D"pt-br">
<head>
    <meta charset=3D"UTF-8">
    <meta name=3D"viewport" content=3D"width=3Ddevice-width, initial-scale=
=3D1.0">
    <title>Meditation App</title>

    <link rel=3D"stylesheet" href=3D"style.css">

    <!-- Google Font -->
    <link href=3D"
https://fonts.googleapis.com/css2?family=3DPoppins:wght@300;400;500;600;700=
&display=3Dswap
" rel=3D"stylesheet">

    <!-- =C3=8Dcones -->
    <link rel=3D"stylesheet"
    href=3D"
https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
</head>

<body>

<div class=3D"phone">

    <!-- Topo -->
    <header>

        <i class=3D"fa-solid fa-arrow-left"></i>

        <i class=3D"fa-solid fa-bars"></i>

    </header>

    <!-- Conte=C3=BAdo -->

    <section class=3D"hero">

        <h1>Meditation</h1>

        <p>
            Stay a short introductory course,
            start trying meditation.
        </p>

        <!-- Ilustra=C3=A7=C3=A3o -->

        <div class=3D"illustration">

            <div class=3D"circle"></div>

            <img src=3D"img/meditation.png" alt=3D"Meditation">

        </div>

    </section>

    <!-- Timer -->

    <section class=3D"timer">

        <h2>45:00</h2>

        <button>Start</button>

    </section>

    <!-- Rodap=C3=A9 -->

    <footer>

        <div class=3D"footer-item">

            <i class=3D"fa-regular fa-circle-play"></i>

            <span>How to meditate</span>

        </div>

        <span class=3D"time">
            15:29
        </span>

    </footer>

</div>

</body>
</html>

