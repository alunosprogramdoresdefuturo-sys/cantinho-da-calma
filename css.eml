*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{

    background:#ececec;

    display:flex;
    justify-content:center;
    align-items:center;

    height:100vh;
}

.phone{

    width:340px;

    background:white;

    border-radius:30px;

    overflow:hidden;

    box-shadow:0 10px 25px rgba(0,0,0,.15);

}

/*==================*/

header{

    display:flex;

    justify-content:space-between;

    padding:25px;

    color:#555;

    font-size:18px;

}

/*==================*/

.hero{

    text-align:center;

    padding:0 25px;

}

.hero h1{

    font-size:36px;

    font-weight:700;

    color:#222;

}

.hero h1::after{

    content:"";

    display:block;

    width:90px;

    height:5px;

    background:#61D7D6;

    margin:8px auto;

    border-radius:10px;

}

.hero p{

    color:#777;

    font-size:13px;

    margin-top:15px;

    line-height:20px;

}

/*==================*/

.illustration{

    position:relative;

    margin-top:30px;

    display:flex;

    justify-content:center;

    align-items:center;

}

.circle{

    width:220px;

    height:220px;

    background:#B9F4F2;

    border-radius:50%;

    position:absolute;

    z-index:0;

}

.illustration img{

    width:220px;

    position:relative;

    z-index:1;

}

/*==================*/

.timer{

    text-align:center;

    margin-top:30px;

}

.timer h2{

    font-size:30px;

    font-weight:500;

    color:#444;

}

.timer button{

    margin-top:20px;

    width:180px;

    height:50px;

    border:none;

    border-radius:40px;

    background:#74E2DF;

    color:white;

    font-size:18px;

    cursor:pointer;

    transition:.3s;

}

.timer button:hover{

    background:#45d0cc;

}

/*==================*/

footer{

    margin-top:45px;

    border-top:1px solid #ddd;

    padding:18px;

    display:flex;

    justify-content:space-between;

    align-items:center;

}

.footer-item{

    display:flex;

    align-items:center;

    gap:10px;

    color:#555;

}

.footer-item i{

    color:#74E2DF;

    font-size:18px;

}

.time{

    color:#888;

    font-size:12px;

}

/*==================*/

@media(max-width:400px){

.phone{

    width:95%;

}

}

